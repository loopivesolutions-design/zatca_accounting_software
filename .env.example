# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=

# ── Accounting ────────────────────────────────────────────────────────────────
# Strict system-account resolution (no fallback to Account.code).
# When unset: defaults to True if DEBUG=False, False if DEBUG=True.
# In production DEBUG=False, Django system check accounting.E001 requires this to be True.
ACCOUNTING_STRICT_SYSTEM_ACCOUNTS=

# Maker–checker: set True in production, then approve via /main/approvals/…/approve/
# Per-scope overrides: MAKER_CHECKER_SALES_INVOICE_POST=false etc.
MAKER_CHECKER_ENABLED=false
# When unset: strict when DEBUG=False — requires_approval policies must have executors (main.E002).
STRICT_APPROVAL_POLICY_INTEGRITY=
# Comma-separated scopes that must be wired to executors for manage.py check (main.E003).
GO_LIVE_REQUIRED_APPROVAL_SCOPES=
# When unset: strict when DEBUG=False — every Account FK model must be in TRANSACTION_SOURCES (accounting.E002).
STRICT_TRANSACTION_SOURCE_REGISTRY=
# Startup clock vs NTP (main/clock_sync.py). Set SKIP_CLOCK_DRIFT_CHECK=1 only with auditor-approved exception.
SKIP_CLOCK_DRIFT_CHECK=
ALLOW_STARTUP_WITHOUT_NTP=
MAX_CLOCK_DRIFT_SECONDS=2
ENFORCE_CLOCK_DRIFT_IN_DEBUG=
# Block sales invoice/credit note posting if last verify_zatca_hash_chain failed (default on when DEBUG=False).
ZATCA_BLOCK_POST_ON_CHAIN_FAILURE=
# Optional QR TLV tags 7–9 (signature hex, SPKI, SPKI hash); confirm with certification profile.
ZATCA_QR_INCLUDE_ECDSA=false
# JournalEntry.post() only via posting services / AccountingEngine (default on when DEBUG=False).
ENFORCE_JOURNAL_ENTRY_POST_GATE=
# Require complete ZATCA evidence bundle after successful HTTP submit (default on when DEBUG=False).
ZATCA_STRICT_EVIDENCE_COMPLETENESS=
# Global decimal context precision (default 28; set 9 only if you accept narrower significant digits).
DECIMAL_CONTEXT_PREC=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=ZATCA Accounting <your_email@gmail.com>

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── ZATCA XAdES signature policy (optional) ───────────────────────────────────
# Enable only if your validator/certification flow requires explicit policy.
ZATCA_REQUIRE_SIGNATURE_POLICY=False
ZATCA_XADES_POLICY_ID=
ZATCA_XADES_POLICY_NAME=
ZATCA_XADES_POLICY_HASH=
ZATCA_XADES_POLICY_HASH_ALGO=http://www.w3.org/2001/04/xmlenc#sha256
ZATCA_XADES_SIGNING_CERT_MODE=both
ZATCA_REQUIRE_KEYINFO_REFERENCE=False
ZATCA_STRICT_PROFILE_MODE=False
# Set True only to accept legacy stored hashes (SHA256(canonical) without previous-hash chaining).
ZATCA_HASH_CHAIN_LEGACY=False
# When unset: matches DEBUG (simulate ZATCA API in dev; live API when DEBUG=False). Set true/false to override.
ZATCA_SIMULATION_MODE=
ZATCA_COUNTRY_CODE=SA
ZATCA_PROFILE_ID=reporting:1.0
ZATCA_PROFILE_ID_INVOICE=reporting:1.0
ZATCA_PROFILE_ID_CREDIT_NOTE=reporting:1.0
ZATCA_INVOICE_TYPE_NAME=0100000
